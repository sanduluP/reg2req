# template for teammates
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<your-local-neo4j-password>

GROQ_API_KEY=your_api_key

KB_ENCODER_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
KB_NORMALIZE_EMBEDDINGS=true
KB_QUALITY_TO_KG_TOP_K=5
KB_MIN_SIMILARITY_THRESHOLD=0.55

# Similarity mode:
# - node_entity compares extracted quality entities with KG source/target node labels.
# - sentence compares full quality sentences with KG relation sentences.
KB_SIMILARITY_MODE=node_entity
KB_ENTITY_EXTRACTION_MODE=keybert
KB_ENTITY_KEYBERT_MODEL_NAME=
KB_ENTITY_KEYBERT_BATCH_SIZE=
KB_ENTITY_KEYBERT_NGRAM_MAX=3
KB_NODE_ENTITY_TOP_K=5
KB_NODE_ENTITY_MAX_ENTITIES_PER_QUALITY=8
# Empty means reuse KB_MIN_SIMILARITY_THRESHOLD.
KB_NODE_ENTITY_MIN_SIMILARITY_THRESHOLD=
# Keyword synonym expansion cache
KB_KEYWORD_SYNONYMS_ENABLED=true
KB_KEYWORD_SYNONYM_CACHE_ENABLED=true
KB_KEYWORD_SYNONYM_CACHE_PATH=runtime/keyword_synonyms_cache.json
KB_KEYWORD_SYNONYM_DEFAULTS_PATH=data/keyword_synonyms.json
KB_KEYWORD_SYNONYM_CACHE_WRITE=true

