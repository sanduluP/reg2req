# Template for teammates. Copy to .env and fill in. Keep runtime tuning + any
# secrets in your local .env (which is git-ignored), NOT here.

# ── Neo4j ───────────────────────────────────────────────────────────────
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<your-local-neo4j-password>

# ── LLM backend ─────────────────────────────────────────────────────────
# The pipeline talks to any OpenAI-compatible /v1/chat/completions endpoint
# via MODEL_BACKEND=http. Pick ONE of the options below in your local .env.
#
# Option A (default for the team): DFKI internal model server — no API key,
# only reachable on the DFKI network / VPN.
MODEL_BACKEND=http
MODEL_SERVICE_URL=http://serv-3306.kl.dfki.de:8000/v1/chat/completions
MODEL_SERVICE_NAME=deepseek-r1:32b
REQUEST_TIMEOUT=3600.0
REQUEST_RETRIES=2
#
# Option B (fallback): a hosted OpenAI-compatible API such as DeepSeek. The
# `http` backend sends `Authorization: Bearer <MODEL_API_KEY>` when a key is
# set. Bring your OWN key — do not commit it.
#   MODEL_SERVICE_URL=https://api.deepseek.com/v1/chat/completions
#   MODEL_SERVICE_NAME=deepseek-chat
#   MODEL_API_KEY=<your-own-deepseek-or-openai-key>
#   REQUEST_TIMEOUT=120.0

# ── Optional: Groq backend ──────────────────────────────────────────────
# GROQ_API_KEY=your_api_key
